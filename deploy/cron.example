# ─── Local cron (the canonical setup) ─────────────────────────────────────────
# Your machine (or any host) runs ./refresh-and-push.sh on a schedule. The
# script pulls latest, regenerates data.json, commits + pushes if anything
# changed. Vercel auto-redeploys from main and the report is live.
#
# Install with `crontab -e`:

# Hourly during business hours, Mon–Fri (Saigon time, ICT = UTC+7).
# Logs to /tmp/altos_refresh.log so you can `tail -f` it.
0 1-12 * * 1-5 cd /Users/quy/claude/altos_report && ./refresh-and-push.sh >> /tmp/altos_refresh.log 2>&1


# ─── macOS launchd alternative ────────────────────────────────────────────────
# Save as ~/Library/LaunchAgents/world.qode.altos-report.plist, then:
#   launchctl bootstrap gui/$UID ~/Library/LaunchAgents/world.qode.altos-report.plist
#
# <?xml version="1.0" encoding="UTF-8"?>
# <!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
# <plist version="1.0"><dict>
#   <key>Label</key><string>world.qode.altos-report</string>
#   <key>ProgramArguments</key>
#     <array>
#       <string>/bin/bash</string><string>-lc</string>
#       <string>cd /Users/quy/claude/altos_report && ./refresh-and-push.sh</string>
#     </array>
#   <key>StartInterval</key><integer>3600</integer>
#   <key>StandardOutPath</key><string>/tmp/altos_refresh.log</string>
#   <key>StandardErrorPath</key><string>/tmp/altos_refresh.log</string>
# </dict></plist>


# ─── Legacy: S3 / GCS upload path (if you ever leave Vercel) ─────────────────
# 0 * * * * cd /opt/altos_report && \
#           DATABASE_URL="${DATABASE_URL}" \
#           /usr/local/bin/python3 refresh.py && \
#           ./deploy/upload.sh s3 >> /var/log/altos_report.log 2>&1
